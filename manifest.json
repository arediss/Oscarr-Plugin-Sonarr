{
  "id": "sonarr",
  "name": "Sonarr Manager",
  "version": "0.1.1",
  "apiVersion": "v1",
  "description": "Advanced Sonarr management: series browser, season/episode drill-down, quality monitoring, releases, analytics and file management.",
  "author": "Arediss",
  "entry": "dist/index.js",
  "frontend": "frontend/index.tsx",
  "services": [
    "sonarr"
  ],
  "hooks": {
    "routes": {
      "prefix": "/api/plugins/sonarr"
    },
    "ui": [
      {
        "hookPoint": "admin.tabs",
        "props": {
          "label": "Sonarr",
          "icon": "Tv"
        },
        "order": 50
      }
    ]
  },
  "engines": {
    "oscarr": ">=0.6.0 <1.0.0",
    "testedAgainst": [
      "0.6.3",
      "0.7.0",
      "0.7.1"
    ]
  }
}
